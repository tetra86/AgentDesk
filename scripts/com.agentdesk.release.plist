<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.agentdesk.release</string>

    <key>ProgramArguments</key>
    <array>
        <string>AGENTDESK_BIN</string>
        <string>dcserver</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>AGENTDESK_ROOT_DIR</key>
        <string>AGENTDESK_HOME</string>
    </dict>

    <key>WorkingDirectory</key>
    <string>AGENTDESK_HOME</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>5</integer>

    <key>StandardOutPath</key>
    <string>AGENTDESK_HOME/logs/dcserver.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>AGENTDESK_HOME/logs/dcserver.stderr.log</string>
</dict>
</plist>
